"import { spawnSync } from 'child_process';
import { readFileSync } from 'fs';

const { containerEngine, image } = JSON.parse(
  readFileSync('config.json', 'utf-8'),
).localDev;

const inspect = spawnSync(containerEngine, ['image', 'inspect', image], {
  stdio: 'ignore',
});
if (inspect.status !== 0) {
  const pull = spawnSync(containerEngine, ['pull', image], {
    stdio: 'inherit',
  });
  if (pull.status !== 0) {
    process.exit(pull.status ?? 1);
  }
}
"
`;

exports[`ts#opensearch generator > should generate the opensearch project > packages/common/scripts/src/opensearch/start-container.ts 1`] = `
"import { spawn, spawnSync } from 'child_process';
import { readFileSync } from 'fs';

const { containerEngine, containerName, image, port } = JSON.parse(
  readFileSync('config.json', 'utf-8'),
).localDev;

const containerExists = (): boolean =>
  spawnSync(containerEngine, ['container', 'inspect', containerName], {
    stdio: 'ignore',
  }).status === 0;

const isRunning = (): boolean => {
  const result = spawnSync(
    containerEngine,
    ['container', 'inspect', '-f', '{{.State.Running}}', containerName],
    { encoding: 'utf-8' },
  );
  return result.status === 0 && result.stdout.trim() === 'true';
};

// Ensure the image is available locally before starting the container.
const ensureImage = (): void => {
  const inspect = spawnSync(containerEngine, ['image', 'inspect', image], {
    stdio: 'ignore',
  });
  if (inspect.status !== 0) {
    const pull = spawnSync(containerEngine, ['pull', image], {
      stdio: 'inherit',
    });
    if (pull.status !== 0) process.exit(pull.status ?? 1);
  }
};

// Multiple OpenSearch packages run dev in parallel sharing the same
// container. All processes stream logs, but only the one that created the
// container stops it on exit — others just detach.
let created = false;
let runRetries = 0;

ensureImage();

for (;;) {
  if (containerExists()) {
    if (!isRunning()) {
      // Another process may have started it between our inspect and start — container engine start
      // exits 0 even if the container is already running, so no special-casing needed.
      const start = spawnSync(containerEngine, ['start', containerName], {
        stdio: 'inherit',
      });
      if (start.status !== 0) process.exit(start.status ?? 1);
    }
    break;
  }
  const runArgs = [
    'run',
    ...(containerEngine === 'docker' ? ['--rm'] : []),
    '--name',
    containerName,
    '-p',
    \`\${port}:9200\`,
    '-e',
    'discovery.type=single-node',
    '-e',
    'plugins.security.disabled=true',
    '-e',
    'DISABLE_INSTALL_DEMO_CONFIG=true',
    '-e',
    'DISABLE_SECURITY_PLUGIN=true',
    '-v',
    \`\${containerName}-data:/usr/share/opensearch/data\`,
    '-d',
    image,
  ];
  const create = spawnSync(containerEngine, runArgs, { stdio: 'pipe' });
  if (create.status === 0) {
    created = true;
    break;
  }
  if (!containerExists() && ++runRetries > 3) {
    process.stderr.write(create.stderr);
    process.exit(create.status ?? 1);
  }
}

const logs = spawn(containerEngine, ['logs', '-f', containerName], {
  stdio: ['ignore', 'inherit', 'inherit'],
});

let exiting = false;

const cleanup = () => {
  if (exiting) return;
  exiting = true;
  if (created) {
    if (containerEngine === 'docker') {
      spawnSync(containerEngine, ['stop', containerName], { stdio: 'ignore' });
    } else {
      spawnSync(containerEngine, ['rm', '-f', containerName], {
        stdio: 'ignore',
      });
    }
  }
  logs.kill();
  process.exit(0);
};

process.on('SIGTERM', cleanup);
process.on('SIGINT', cleanup);
process.on('SIGHUP', cleanup);

logs.on('exit', (code) => {
  if (!exiting) process.exit(code ?? 0);
});
"
`;

exports[`ts#opensearch generator > should generate the opensearch project > packages/common/scripts/src/opensearch/sync-index-mappings.ts 1`] = `
"import { readFileSync, writeFileSync } from 'fs';
import { loadIndexDefinitions } from './sync-indices-lib.js';

// Runs as a build step (see the \`sync-mappings\` target) so config.json's
// \`indices\` is always a fresh snapshot of the zod schemas under src/indices/.
// The CDK app construct (a different Nx project, so it can't import these zod
// modules directly at synth time) reads this snapshot to declare a
// \`CfnIndex\` per index - the same reason DynamoDB's GSIs are snapshotted into
// config.json rather than read from the entity source directly.
const configPath = 'config.json';
const config = JSON.parse(readFileSync(configPath, 'utf-8'));

config.indices = (await loadIndexDefinitions()).map(
  ({ indexName, mapping }) => ({
    indexName,
    mapping: mapping.mappings,
  }),
);

writeFileSync(configPath, \`\${JSON.stringify(config, null, 2)}\\n\`);
"
`;

exports[`ts#opensearch generator > should generate the opensearch project > packages/common/scripts/src/opensearch/sync-indices.ts 1`] = `
"import { Client } from '@opensearch-project/opensearch';
import { AwsSigv4Signer } from '@opensearch-project/opensearch/aws';
import { defaultProvider } from '@aws-sdk/credential-provider-node';
import {
  ensureIndex,
  loadIndexDefinitions,
  waitForCluster,
} from './sync-indices-lib.js';

// Invoked by the Terraform module (via a null_resource local-exec) after the
// collection is created, using the deployer's own AWS credentials - Terraform
// has no native resource for OpenSearch Serverless indices, unlike CDK's
// \`AWS::OpenSearchServerless::Index\`, so this runs the same sync logic used
// for local dev against the real collection instead.
const collectionEndpoint = process.env.OPENSEARCH_COLLECTION_ENDPOINT;
const region = process.env.AWS_REGION;
if (!collectionEndpoint || !region) {
  throw new Error(
    'OPENSEARCH_COLLECTION_ENDPOINT and AWS_REGION environment variables are required',
  );
}

const client = new Client({
  ...AwsSigv4Signer({
    region,
    service: 'aoss',
    getCredentials: () => defaultProvider()(),
  }),
  node: collectionEndpoint,
});

await waitForCluster(client);

for (const { indexName, mapping } of await loadIndexDefinitions()) {
  await ensureIndex(client, indexName, mapping);
}
"
`;

exports[`ts#opensearch generator > should generate the opensearch project > packages/common/scripts/src/opensearch/sync-indices-lib.ts 1`] = `
"import { readdirSync } from 'fs';
import { resolve } from 'path';
import { pathToFileURL } from 'url';
import type { Client } from '@opensearch-project/opensearch';

// Structurally matches OpenSearchIndexDefinition/zodSchemaToOpenSearchMapping
// from the calling project's generated src/zod-to-mapping.ts. Declared locally
// rather than imported: this module is shared across every ts#opensearch
// project, each with its own zod-to-mapping.ts at a different relative path,
// so the module it loads at runtime (below) can only be resolved dynamically.
interface OpenSearchIndexDefinition {
  indexName: string;
  schema: { parse: (value: unknown) => unknown };
}
type OpenSearchMapping = { mappings: { properties: Record<string, unknown> } };
type ZodToMappingModule = {
  zodSchemaToOpenSearchMapping: (schema: unknown) => OpenSearchMapping;
  isOpenSearchIndexDefinition: (
    value: unknown,
  ) => value is OpenSearchIndexDefinition;
};

export interface ResolvedIndex {
  indexName: string;
  mapping: OpenSearchMapping;
}

// Always invoked with cwd set to the calling project's root, so the project's
// own zod schemas (the single source of truth for each index's mapping) are
// resolved relative to process.cwd() rather than this module's own location.
export const loadIndexDefinitions = async (): Promise<ResolvedIndex[]> => {
  const { zodSchemaToOpenSearchMapping, isOpenSearchIndexDefinition } =
    (await import(
      pathToFileURL(resolve('src/zod-to-mapping.ts')).href
    )) as ZodToMappingModule;

  const indicesDir = resolve('src/indices');
  const files = readdirSync(indicesDir).filter(
    (f) => f.endsWith('.ts') && f !== 'index.ts',
  );
  const modules = await Promise.all(
    files.map((f) => import(pathToFileURL(resolve(indicesDir, f)).href)),
  );
  const definitions = modules.flatMap((mod) =>
    Object.values(mod).filter(isOpenSearchIndexDefinition),
  );

  return definitions.map(({ indexName, schema }) => ({
    indexName,
    mapping: zodSchemaToOpenSearchMapping(schema),
  }));
};

export const waitForCluster = async (client: Client): Promise<void> => {
  for (;;) {
    try {
      await client.cluster.health({}, { requestTimeout: 10000 });
      return;
    } catch {
      await new Promise((r) => setTimeout(r, 500));
    }
  }
};

export const ensureIndex = async (
  client: Client,
  indexName: string,
  mapping: OpenSearchMapping,
): Promise<void> => {
  const { body: exists } = await client.indices.exists(
    { index: indexName },
    { requestTimeout: 10000 },
  );
  if (!exists) {
    // Cast: \`mapping\` is intentionally untyped against opensearch-js's own
    // \`Property\` union (a closed set of concrete field-mapping shapes) so this
    // module stays framework-agnostic - the same mapping also has to satisfy
    // CDK's independently-typed \`CfnIndex.MappingsProperty\` (see the app
    // construct template), and both are structurally satisfied at runtime.
    await client.indices.create(
      { index: indexName, body: mapping as any },
      { requestTimeout: 10000 },
    );
    console.log(\`Created index: \${indexName}\`);
    return;
  }
  // Existing index: OpenSearch only allows adding new fields via putMapping -
  // changing or removing an existing field's mapping is rejected. A breaking
  // schema change requires the standard reindex-and-alias-swap approach.
  await client.indices.putMapping(
    { index: indexName, body: mapping.mappings as any },
    { requestTimeout: 10000 },
  );
  console.log(\`Updated mapping: \${indexName}\`);
};
"
`;

exports[`ts#opensearch generator > should generate the opensearch project > packages/my-search/src/client.ts 1`] = `
"import { Client } from '@opensearch-project/opensearch';
import { AwsSigv4Signer } from '@opensearch-project/opensearch/aws';
import { defaultProvider } from '@aws-sdk/credential-provider-node';
import { getAppConfig } from '@aws-lambda-powertools/parameters/appconfig';
import { readFileSync } from 'fs';
import { join, dirname } from 'path';
import { fileURLToPath } from 'url';

// Generated: must match runtimeConfigKey in config.json
const runtimeConfigKey = 'MySearch';

const __dirname = dirname(fileURLToPath(import.meta.url));
// config.json is only present in local dev (not included in the deployed bundle); guard with LOCAL_DEV check
const localDev = () =>
  JSON.parse(readFileSync(join(__dirname, '../config.json'), 'utf-8')).localDev;

type OpenSearchConfig = {
  collectionEndpoint: string;
  region: string;
};

let _config: OpenSearchConfig | undefined;

// Resolves both the endpoint and region together since the SigV4 signer needs
// the collection's region, which (unlike DynamoDB's fixed regional endpoint)
// varies per-collection and so must come from the same runtime config lookup.
const resolveConfig = async (): Promise<OpenSearchConfig> => {
  if (process.env.LOCAL_DEV === 'true') {
    const { port } = localDev();
    return {
      collectionEndpoint: \`http://localhost:\${port}\`,
      region: 'us-east-1',
    };
  }
  if (_config === undefined) {
    const appId = process.env.RUNTIME_CONFIG_APP_ID;
    if (!appId) {
      throw new Error('RUNTIME_CONFIG_APP_ID environment variable is not set');
    }
    const config = await getAppConfig<{
      [key: string]: OpenSearchConfig | undefined;
    }>('opensearch', {
      application: appId,
      environment: 'default',
      transform: 'json',
    });
    const resolved = config?.[runtimeConfigKey];
    if (!resolved?.collectionEndpoint) {
      throw new Error(
        'Could not resolve OpenSearch collection endpoint from runtime config',
      );
    }
    _config = resolved;
  }
  return _config;
};

export const resolveCollectionEndpoint = async (): Promise<string> =>
  (await resolveConfig()).collectionEndpoint;

let _client: Client | undefined;

// Unlike getDynamoDBClient, this is async: the collection endpoint (the
// client's \`node\`) must be resolved before the client can be constructed,
// rather than being a fixed regional endpoint known up front.
export const getOpenSearchClient = async (): Promise<Client> => {
  if (!_client) {
    const { collectionEndpoint, region } = await resolveConfig();
    _client =
      process.env.LOCAL_DEV === 'true'
        ? new Client({ node: collectionEndpoint })
        : new Client({
            ...AwsSigv4Signer({
              region,
              service: 'aoss',
              getCredentials: () => defaultProvider()(),
            }),
            node: collectionEndpoint,
          });
  }
  return _client;
};
"
`;

