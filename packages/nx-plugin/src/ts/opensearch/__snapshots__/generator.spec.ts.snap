exports[`ts#opensearch generator > should generate the opensearch project > packages/my-search/src/zod-to-mapping.ts 1`] = `
"import { z } from 'zod';

// OpenSearch-specific mapping overrides for a field, set via \`.meta({ opensearch: {...} })\`.
// Needed wherever zod's type system doesn't distinguish an OpenSearch field type
// (eg. \`keyword\` vs \`text\`) or has no equivalent at all (eg. \`knn_vector\`, \`geo_point\`).
export interface OpenSearchFieldOverride {
  type?: string;
  dimension?: number;
  method?: {
    name?: string;
    spaceType?: string;
    engine?: string;
    parameters?: Record<string, unknown>;
  };
  [key: string]: unknown;
}

interface JsonSchemaNode {
  type?: string | string[];
  format?: string;
  properties?: Record<string, JsonSchemaNode>;
  items?: JsonSchemaNode;
  opensearch?: OpenSearchFieldOverride;
}

const inferType = (node: JsonSchemaNode): string => {
  const type = Array.isArray(node.type) ? node.type[0] : node.type;
  switch (type) {
    case 'string':
      return node.format === 'date-time' ? 'date' : 'text';
    case 'number':
      return 'float';
    case 'integer':
      return 'long';
    case 'boolean':
      return 'boolean';
    case 'object':
      return 'object';
    default:
      return 'text';
  }
};

const nodeToProperty = (node: JsonSchemaNode): Record<string, unknown> => {
  if (node.opensearch) {
    const { type, ...rest } = node.opensearch;
    return { type: type ?? inferType(node), ...rest };
  }

  const type = Array.isArray(node.type) ? node.type[0] : node.type;

  if (type === 'object' && node.properties) {
    return {
      type: 'object',
      properties: Object.fromEntries(
        Object.entries(node.properties).map(([key, value]) => [
          key,
          nodeToProperty(value),
        ]),
      ),
    };
  }

  if (type === 'array' && node.items) {
    // OpenSearch has no distinct array mapping type - an array of primitives
    // maps the same way as a single value of that type would.
    return nodeToProperty(node.items);
  }

  return { type: inferType(node) };
};

/**
 * Derives an OpenSearch index mapping from a zod object schema. Field types are
 * inferred from the zod shape; use \`.meta({ opensearch: {...} })\` on a field to
 * override the inferred type or add mapping parameters (eg. \`knn_vector\`
 * dimension/method for vector search fields).
 */
export const zodSchemaToOpenSearchMapping = (
  schema: z.ZodObject<any>,
): { mappings: { properties: Record<string, unknown> } } => {
  const jsonSchema = z.toJSONSchema(schema, {
    io: 'output',
  }) as JsonSchemaNode;
  const properties = jsonSchema.properties ?? {};
  return {
    mappings: {
      properties: Object.fromEntries(
        Object.entries(properties).map(([key, value]) => [
          key,
          nodeToProperty(value),
        ]),
      ),
    },
  };
};

// Pairs an index name with the zod schema that defines its documents. Export
// one of these per index module (see indices/example.ts) so local-dev and
// deploy-time tooling can discover every index in the project without relying
// on file/export naming conventions.
export interface OpenSearchIndexDefinition<
  T extends z.ZodObject<any> = z.ZodObject<any>,
> {
  indexName: string;
  schema: T;
}

export const isOpenSearchIndexDefinition = (
  value: unknown,
): value is OpenSearchIndexDefinition =>
  typeof value === 'object' &&
  value !== null &&
  typeof (value as OpenSearchIndexDefinition).indexName === 'string' &&
  typeof (value as OpenSearchIndexDefinition).schema?.parse === 'function';
"
`;

exports[`ts#opensearch generator > should generate the opensearch project 1`] = `
"import { Construct } from 'constructs';
import { Stack } from 'aws-cdk-lib';
import {
  CfnAccessPolicy,
  CfnCollection,
  CfnCollectionProps,
  CfnSecurityPolicy,
} from 'aws-cdk-lib/aws-opensearchserverless';
import { Grant, IRole } from 'aws-cdk-lib/aws-iam';
import { Key } from 'aws-cdk-lib/aws-kms';
import { RuntimeConfig } from './runtime-config.js';

type _CollectionProps = Omit<CfnCollectionProps, 'name' | 'type'>;

export interface OpenSearchCollectionProps extends _CollectionProps {
  /**
   * The OpenSearch Serverless collection name. Must be lowercase, 3-28
   * characters, and contain only letters, numbers and hyphens.
   */
  readonly collectionName: string;

  /**
   * Collection type - VECTORSEARCH for RAG/vector search workloads, SEARCH
   * for general text search, TIMESERIES for log/metric data.
   * @default 'VECTORSEARCH'
   */
  readonly type?: 'SEARCH' | 'VECTORSEARCH' | 'TIMESERIES';

  /**
   * RuntimeConfig key used under the \`opensearch\` namespace.
   */
  readonly runtimeConfigKey: string;

  /**
   * Whether to enable automatic key rotation on the KMS key used to encrypt the collection.
   * @default true
   */
  readonly enableKeyRotation?: boolean;
}

// Keyed by grantee role ARN so a repeat grant to the same role widens its
// existing Rules entry instead of appending a duplicate.
interface AccessPolicyStatement {
  readonly Rules: {
    ResourceType: 'index';
    Resource: string[];
    Permission: string[];
  }[];
  readonly Principal: string[];
}

export abstract class OpenSearchCollection extends Construct {
  public readonly collection: CfnCollection;
  // protected (not private) so app construct subclasses can depend a CfnIndex
  // on it - index creation must wait until the access policy, which needs to
  // include the deploying principal, has been applied.
  protected readonly accessPolicy: CfnAccessPolicy;
  private readonly statementsByRoleArn = new Map<
    string,
    AccessPolicyStatement
  >();

  constructor(
    scope: Construct,
    id: string,
    {
      collectionName,
      type = 'VECTORSEARCH',
      runtimeConfigKey,
      enableKeyRotation = true,
      ...rest
    }: OpenSearchCollectionProps,
  ) {
    super(scope, id);

    const key = new Key(this, 'EncryptionKey', { enableKeyRotation });

    const encryptionPolicy = new CfnSecurityPolicy(this, 'EncryptionPolicy', {
      name: \`\${collectionName}-encryption\`,
      type: 'encryption',
      policy: JSON.stringify({
        Rules: [
          {
            ResourceType: 'collection',
            Resource: [\`collection/\${collectionName}\`],
          },
        ],
        AWSOwnedKey: false,
        KmsARN: key.keyArn,
      }),
    });

    const networkPolicy = new CfnSecurityPolicy(this, 'NetworkPolicy', {
      name: \`\${collectionName}-network\`,
      type: 'network',
      policy: JSON.stringify([
        {
          Rules: [
            {
              ResourceType: 'collection',
              Resource: [\`collection/\${collectionName}\`],
            },
            {
              ResourceType: 'dashboard',
              Resource: [\`collection/\${collectionName}\`],
            },
          ],
          AllowFromPublic: true,
        },
      ]),
    });

    // Starts with no principals - populated by grant calls below (and must
    // also include whichever identity deploys this stack, since creating the
    // CfnIndex resources declared by the app construct is itself a data-plane
    // operation gated by this policy, not just the deployer's own IAM permissions).
    this.accessPolicy = new CfnAccessPolicy(this, 'AccessPolicy', {
      name: \`\${collectionName}-access\`,
      type: 'data',
      policy: JSON.stringify([]),
    });

    this.collection = new CfnCollection(this, 'Collection', {
      ...rest,
      name: collectionName,
      type,
    });
    this.collection.addDependency(encryptionPolicy);
    this.collection.addDependency(networkPolicy);
    this.collection.node.addDependency(this.accessPolicy);

    const rc = RuntimeConfig.ensure(this);
    rc.set('opensearch', runtimeConfigKey, {
      collectionEndpoint: this.collection.attrCollectionEndpoint,
      region: Stack.of(this).region,
    });
  }

  /** Grants read (search/get document) access to every index in the collection. */
  public grantReadData(grantee: IRole): Grant {
    return this.grant(grantee, ['aoss:ReadDocument']);
  }

  /** Grants write (index/update/delete document, create/update/delete index) access. */
  public grantWriteData(grantee: IRole): Grant {
    return this.grant(grantee, [
      'aoss:CreateIndex',
      'aoss:UpdateIndex',
      'aoss:DeleteIndex',
      'aoss:WriteDocument',
    ]);
  }

  /** Grants both read and write access. */
  public grantReadWriteData(grantee: IRole): Grant {
    return this.grant(grantee, [
      'aoss:CreateIndex',
      'aoss:UpdateIndex',
      'aoss:DeleteIndex',
      'aoss:ReadDocument',
      'aoss:WriteDocument',
    ]);
  }

  /**
   * Grants OpenSearch Serverless data-plane access. Unlike a typical CDK
   * resource grant, this requires two halves that AOSS checks on every
   * request: an identity-based IAM policy statement (\`Grant.addToPrincipal\`,
   * as usual) *and* an entry in the collection's data access policy naming the
   * grantee's role ARN and the index-level permissions it's allowed. Takes
   * \`IRole\` rather than the broader \`IGrantable\` because an access policy
   * statement must reference a concrete IAM principal ARN, which isn't
   * available on every \`IGrantable\` (e.g. a \`ServicePrincipal\`).
   */
  private grant(grantee: IRole, indexPermissions: string[]): Grant {
    const existing = this.statementsByRoleArn.get(grantee.roleArn);
    if (existing) {
      const rule = existing.Rules[0];
      rule.Permission = [...new Set([...rule.Permission, ...indexPermissions])];
    } else {
      this.statementsByRoleArn.set(grantee.roleArn, {
        Principal: [grantee.roleArn],
        Rules: [
          {
            ResourceType: 'index',
            Resource: [\`index/\${this.collection.name}/*\`],
            Permission: [...indexPermissions],
          },
        ],
      });
    }
    this.accessPolicy.policy = JSON.stringify([
      ...this.statementsByRoleArn.values(),
    ]);

    return Grant.addToPrincipal({
      grantee,
      actions: ['aoss:APIAccessAll'],
      resourceArns: [this.collection.attrArn],
    });
  }
}
"
`;

exports[`ts#opensearch generator > should generate the opensearch project 2`] = `
"import { Construct } from 'constructs';
import { CfnIndex } from 'aws-cdk-lib/aws-opensearchserverless';
import {
  OpenSearchCollection,
  OpenSearchCollectionProps,
} from '../../core/opensearch.js';
import { findWorkspaceRoot } from '../../core/workspace.js';
import { readFileSync } from 'fs';
import { join } from 'path';
import { fileURLToPath } from 'url';

const { runtimeConfigKey, indices } = JSON.parse(
  readFileSync(
    join(
      findWorkspaceRoot(fileURLToPath(new URL(import.meta.url))),
      'packages/my-search/config.json',
    ),
    'utf-8',
  ),
) as {
  runtimeConfigKey: string;
  indices: {
    indexName: string;
    mapping: { properties: Record<string, unknown> };
  }[];
};

export type MySearchProps = Omit<
  OpenSearchCollectionProps,
  'runtimeConfigKey' | 'collectionName'
> & {
  collectionName?: string;
};

export class MySearch extends OpenSearchCollection {
  constructor(scope: Construct, id: string, props?: MySearchProps) {
    super(scope, id, {
      collectionName: 'my-search',
      ...props,
      runtimeConfigKey,
    });

    for (const { indexName, mapping } of indices) {
      const index = new CfnIndex(this, \`Index\${indexName}\`, {
        collectionEndpoint: this.collection.attrCollectionEndpoint,
        indexName,
        // Cast: \`mapping\` (from config.json, derived from zod at build time) is
        // intentionally untyped against CfnIndex's own PropertyMappingProperty
        // union so the mapping format stays shared with the opensearch-js
        // client calls in sync-indices-lib.ts - both are structurally satisfied
        // at runtime.
        mappings: mapping as CfnIndex.MappingsProperty,
      });
      index.node.addDependency(this.collection);
      index.node.addDependency(this.accessPolicy);
    }
  }
}
"
`;

